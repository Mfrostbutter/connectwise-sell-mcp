# ConnectWise Sell (Quosal) API credentials
# Auth = base64(SELL_ACCESS_KEY+SELL_USERNAME:SELL_PASSWORD)
# Access key: log into Sell and check the URL parameters
SELL_ACCESS_KEY=your_access_key
SELL_USERNAME=your_api_username
SELL_PASSWORD=your_password

# Base URL — default works for most instances
# SELL_BASE_URL=https://sellapi.quosalsell.com

# MCP server auth (optional — omit to disable bearer token requirement)
MCP_AUTH_TOKEN=your_secret_token

# Transport: "http" (default, persistent server) or "stdio" (per-session, works with Cursor/VS Code/etc.)
# MCP_TRANSPORT=http

# Port — only used when MCP_TRANSPORT=http (default 8086)
SELL_MCP_PORT=8086
